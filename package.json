{
  "name": "edumind-ai",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.7.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "supabase/functions/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prepare": "husky install"
  },
  "devDependencies": {
    "turbo": "^2.0.10",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.10",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,css,md}": "prettier --write"
  }
}